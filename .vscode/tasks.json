{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Core Debug-x64",
            "command": "msbuild",
            "type": "shell",
            "args": [
                "Core\\Core.sln",
                "/t:Build",
                "/p:Configuration=Debug",
                "/p:Platform=x64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Foundation",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "Foundation\\Foundation.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        }
    ]
}